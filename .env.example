DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional: GitHub OAuth
GITHUB_ID=""
GITHUB_SECRET=""

# Optional: local/dev credential fallback (enabled in non-production)
DEV_LOGIN_EMAIL="dev@algosprint.local"
DEV_LOGIN_PASSWORD="devpass123"

# Optional: admin access for /admin/harness in production
ADMIN_EMAILS=""

# Optional: distributed-ready infrastructure
REDIS_URL=""
QUEUE_WORKER_MODE="embedded" # embedded | external
WORKER_API_TOKEN=""
WORKER_AUTH_TOLERANCE_MS="300000"
WORKER_BASE_URL="http://localhost:3000"
WORKER_LOOP_INTERVAL_MS="1500"
RUNNER_MAX_CONCURRENCY="2"
RUNNER_EXECUTION_MODE="local" # local | isolated
RUNNER_ISOLATED_COMMAND="" # isolated mode hook command
RUNNER_CPU_TIME_SECONDS="2"
RUNNER_MEMORY_LIMIT_KB="262144"
QUEUE_AVG_JOB_SECONDS="6"
SLO_WINDOW_HOURS="24"

# UI warning control
NEXT_PUBLIC_RUNNER_SANDBOXED="0"
NEXT_PUBLIC_RUNNER_SAFE_MODE="0"
